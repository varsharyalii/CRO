# PostHog (read-only Query API)
POSTHOG_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# Repo grounding — local checkout of jhaazi-frontend that file paths resolve against
JHAAZI_FRONTEND_PATH=../jhaazi-frontend

# GitHub (token scoped to issues:write on jhaazi-frontend)
GITHUB_TOKEN=
GITHUB_REPO=Jhaazi/jhaazi-frontend

# LLM — provider-agnostic (groq | anthropic)
LLM_PROVIDER=groq
CRO_AGENT_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Analysis window (days) and gates
ANALYSIS_WINDOW_DAYS=14
MIN_SAMPLE_SIZE=100

# Caps
MAX_LLM_CALLS=25
